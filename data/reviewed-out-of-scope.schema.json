{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guwidoe.github.io/awesome-group-generators/data/reviewed-out-of-scope.schema.json",
  "title": "Reviewed but out-of-scope group-generation-adjacent resources",
  "type": "object",
  "required": ["metadata", "items"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "description", "reviewedAt", "itemCount", "policy", "decisionStatuses"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reviewedAt": { "type": "string" },
        "itemCount": { "type": "integer", "minimum": 0 },
        "policy": { "type": "string" },
        "decisionStatuses": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "url", "category", "decisionStatus", "whyOutOfScope", "publicEvidence", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "category": { "type": "string" },
          "decisionStatus": {
            "type": "string",
            "enum": [
              "sales-gated",
              "platform-native",
              "documentation-only",
              "research-reference",
              "app-store-only",
              "duplicate-or-variant",
              "unavailable",
              "parked-or-dead",
              "broken-or-nonfunctional",
              "spam-or-redirect",
              "not-a-group-generator",
              "adjacent-commercial"
            ]
          },
          "whyOutOfScope": { "type": "string" },
          "publicEvidence": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
